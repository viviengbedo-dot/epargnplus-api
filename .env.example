# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (Supabase connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=change_me_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=30d

# AfricasTalking SMS
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key
AT_SENDER_ID=EpargnPlus

# OTP config
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Demo credentials (bypass real SMS for App Store review)
DEMO_PHONE=224620000000
DEMO_OTP=123456

# Mobile Money merchant numbers (for manual deposit confirmation)
ORANGE_MONEY_NUMBER=+224 621 000 000
MTN_MOMO_NUMBER=+224 660 000 000
